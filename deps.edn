{:paths ["src"]
 ;; Zero THIRD-PARTY runtime dependencies by design (ADR-0001): every namespace
 ;; is .cljc and runs on JVM Clojure, ClojureScript, SCI, and Clojure-on-WASM.
 ;; The one dep is the sibling kotoba-lang/json (first-party, zero-dep) — the
 ;; in-language JSON parser that replaces the old host-injected seam. langchain
 ;; is a consumer of kotoba-lang/json (a real vertical lib depending on a
 ;; foundational-stdlib lib; M5 for json).
 :deps {io.github.kotoba-lang/json {:git/sha "deb01e68fc6ddd936953575ef54f06dc26f89640"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
